  Node2 [id="Node000002",label="LocalPlayer",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$class_local_player.html",tooltip="Client-side representation of a local (human-controlled) player."];
  Node1 -> Node2 [id="edge2_Node000001_Node000002",dir="back",color="steelblue1",style="solid",tooltip=" "];
