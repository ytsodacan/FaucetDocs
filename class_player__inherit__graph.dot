  Node3 [id="Node000003",label="ServerPlayer",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$class_server_player.html",tooltip="Server-side representation of a connected player."];
  Node1 -> Node3 [id="edge4_Node000001_Node000003",dir="back",color="steelblue1",style="solid",tooltip=" "];
